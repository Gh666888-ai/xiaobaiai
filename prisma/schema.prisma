generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  avatar    String?
  role      String   @default("user") // user | editor | admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tools      Tool[]
  newsItems  NewsItem[]
}

// AI 工具
model Tool {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String
  category    String   // 对话AI | AI绘图 | AI视频 | ...
  stage       Int      @default(0) // 0-7 学习阶段
  pricing     String   @default("免费")
  tags        String[] @default([])
  featured    Boolean  @default(false)
  status      String   @default("pending") // pending | approved | rejected
  submittedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submitter User? @relation(fields: [submittedBy], references: [id])
}

// 新闻资讯
model NewsItem {
  id               String   @id @default(cuid())
  title            String
  summary          String
  url              String?
  source           String   @default("用户投稿")
  category         String   // 行业动态 | 产品发布 | ...
  isAutoGenerated  Boolean  @default(false)
  status           String   @default("pending")
  submittedBy      String?
  publishedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  submitter User? @relation(fields: [submittedBy], references: [id])
}
