NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# 站内“小白AI助手”对话能力，兼容 OpenAI 格式接口。
# DeepSeek 示例：
# AI_CHAT_BASE_URL=https://api.deepseek.com
# AI_CHAT_MODEL=deepseek-v4-flash
# AI_CHAT_API_KEY=sk-xxxx
AI_CHAT_BASE_URL=https://api.deepseek.com
AI_CHAT_MODEL=deepseek-v4-flash
AI_CHAT_API_KEY=

# 小白应用工坊：客户输入一句需求后，用模型生成不同类型的 H5 应用原型。
# 不填时会复用上面的 AI_CHAT_* 配置；需要单独给工坊换模型时再填写。
AI_APP_FACTORY_BASE_URL=
AI_APP_FACTORY_MODEL=
AI_APP_FACTORY_API_KEY=

# AI news cover generation. Used only when running:
# npm run generate:news-covers
# Leave empty to avoid paid image generation calls.
OPENAI_API_KEY=
NEWS_IMAGE_API_KEY=
NEWS_IMAGE_MODEL=gpt-image-1
NEWS_IMAGE_SIZE=1024x1024
NEWS_IMAGE_QUALITY=low
NEWS_IMAGE_MAX=8

# 用于调用 Liblib API 生成小白AI吉祥物动作素材。只在本地/服务器手动运行 npm run generate:mascot 时使用。
# 不要把真实 key 提交到 git，也不要写进前端 NEXT_PUBLIC_* 变量。
LIBLIB_ACCESS_KEY=
LIBLIB_SECRET_KEY=
LIBLIB_TEMPLATE_UUID=9c7d531dc75f476aa833b3d452b8f7ad
LIBLIB_CHECKPOINT_ID=0ea388c7eb854be3ba3c6f65aac6bfd3
